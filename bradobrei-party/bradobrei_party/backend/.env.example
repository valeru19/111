# =============================================================================
# Bradobrei Party — backend: переменные окружения
# =============================================================================
# Скопируйте этот файл в ".env" в ТОЙ ЖЕ папке (backend/) и подставьте свои значения.
# Файл ".env" в git не коммитится (.gitignore).
#
# Где что читается:
#   • Запуск через Docker Compose (папка bradobrei_party/):
#       compose подключает env_file: backend/.env
#       НО переменные DB_*, PORT, GOTENBERG_URL в compose переопределяются — см. ниже.
#   • Локальный запуск "go run ./cmd/api" из папки backend/:
#       нужны все переменные, включая DB_* и PORT, как в блоке «Локально без Docker».
# =============================================================================

# Обязательно. Секрет подписи JWT — любая длинная случайная строка (не делитесь и не коммитьте).
JWT_SECRET=замените_на_длинную_случайную_строку

# debug — подробные логи Gin; release — тише, для «боевого» режима.
GIN_MODE=release

# -----------------------------------------------------------------------------
# Геокодер (адрес → координаты для салонов и POST /api/v1/salons/geocode)
# -----------------------------------------------------------------------------
# Провайдер: none | yandex | google
#   none  — геокодер выключен: кнопка геокодинга в API вернёт ошибку; салон можно
#           сохранить, если координаты заданы вручную (см. логику сервиса).
#   yandex — HTTP API Яндекса (ключ ниже).
#   google — Geocoding API Google (ключ ниже).

GEOCODER_PROVIDER=none

# Если GEOCODER_PROVIDER=yandex — ключ HTTP Геокодера (не путать с ключом только для JavaScript API).
# Получить: кабинет разработчика Яндекса https://developer.tech.yandex.ru/
# В настройках ключа должна быть доступна услуга «Геокодер» (иначе часто HTTP 403).
YANDEX_GEOCODER_API_KEY=

# Если GEOCODER_PROVIDER=google — ключ с включённым Geocoding API в Google Cloud Console.
# https://console.cloud.google.com/apis/library/geocoding-backend.googleapis.com
# Для сервера имеет смысл ограничить ключ по IP вашего сервера / Docker-хоста.
GOOGLE_GEOCODER_API_KEY=

# -----------------------------------------------------------------------------
# Ниже — только для локального запуска БЕЗ Docker (go run ./cmd/api)
# При docker compose эти значения задаются в docker-compose.yml и подменяют .env
# -----------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_NAME=bradobrei
# DB_SSLMODE=disable
#
# PORT=9000
# GOTENBERG_URL=http://localhost:3000
